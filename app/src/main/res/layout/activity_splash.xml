<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#005561"
    tools:context=".SplashActivity">

    <ImageView
        android:id="@+id/image_text_praynow"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:src="@drawable/ic_praynow"
        android:contentDescription="Teks PrayNow"
        android:adjustViewBounds="true"
        android:maxWidth="250dp"

        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.55" />

    <ImageView
        android:id="@+id/image_icon_moon"
        android:layout_width="23dp"
        android:layout_height="40dp"
        android:layout_marginEnd="4dp"
        android:layout_marginBottom="4dp"

        android:contentDescription="Icon Bulan"
        android:src="@drawable/ic_bulan"
        app:layout_constraintBottom_toTopOf="@id/image_text_praynow"
        app:layout_constraintEnd_toEndOf="@id/image_text_praynow"

        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="1.0" />

</androidx.constraintlayout.widget.ConstraintLayout>